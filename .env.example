# Web3Forms Access Key (NEXT_PUBLIC_ prefix = accessible from client-side code)
# Sign up for free at https://web3forms.com (30 seconds, no credit card)
# Paste your access key below. This key is intentionally public (Web3Forms free plan
# requires client-side submission — the key is visible in browser source code by design).
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# Site URL (used for sitemap and canonical URLs)
# Change to your actual domain when deploying
NEXT_PUBLIC_SITE_URL=https://pslaboratories.in
